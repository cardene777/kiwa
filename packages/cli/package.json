{
  "name": "@kiwa/cli",
  "version": "0.0.0",
  "description": "CLI for kiwa (init / doctor commands)",
  "license": "MIT",
  "keywords": ["kiwa", "cli", "scaffold"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cardene777/kiwa.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/cardene777/kiwa#readme",
  "bugs": {
    "url": "https://github.com/cardene777/kiwa/issues"
  },
  "type": "module",
  "bin": {
    "kiwa": "./dist/index.js"
  },
  "files": ["dist", "README.md", "README.ja.md"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --onSuccess \"node -e \\\"require('node:fs').cpSync('src/templates','dist/templates',{recursive:true})\\\"\"",
    "test": "node -e \"require('node:fs').rmSync('.vitest-dist',{recursive:true,force:true})\" && tsc -p tsconfig.vitest.json && vitest run .vitest-dist/tests --environment node --no-file-parallelism",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
