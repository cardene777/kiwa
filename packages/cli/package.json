{
  "name": "@dapp-e2e/cli",
  "version": "0.0.0",
  "description": "CLI for dapp-e2e (init / doctor commands)",
  "license": "MIT",
  "keywords": ["dapp-e2e", "cli", "scaffold"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cardene777/dapp-e2e.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/cardene777/dapp-e2e#readme",
  "bugs": {
    "url": "https://github.com/cardene777/dapp-e2e/issues"
  },
  "type": "module",
  "bin": {
    "dapp-e2e": "./dist/index.js"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --onSuccess \"node -e \\\"require('node:fs').cpSync('src/templates','dist/templates',{recursive:true})\\\"\"",
    "test": "node -e \"require('node:fs').rmSync('.vitest-dist',{recursive:true,force:true})\" && tsc -p tsconfig.vitest.json && vitest run .vitest-dist/tests --environment node --no-file-parallelism",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
