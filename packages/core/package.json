{
  "name": "@dapp-e2e/core",
  "version": "0.0.0",
  "description": "Headless E2E test fixture for dApps on anvil forks (Playwright + viem)",
  "license": "MIT",
  "keywords": ["dapp", "ethereum", "e2e", "playwright", "anvil", "viem", "testing", "fixture"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cardene777/dapp-e2e.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/cardene777/dapp-e2e#readme",
  "bugs": {
    "url": "https://github.com/cardene777/dapp-e2e/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "test": "node -e \"require('node:fs').rmSync('.vitest-dist',{recursive:true,force:true})\" && tsc -p tsconfig.vitest.json && vitest run .vitest-dist/tests --environment node --testTimeout 15000 --no-file-parallelism",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@playwright/test": "^1.49.0",
    "viem": "^2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "viem": "^2.21.0"
  }
}
