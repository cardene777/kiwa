{
  "name": "@kiwa-test/core",
  "version": "0.1.2",
  "description": "Headless E2E test fixture for dApps on anvil forks (Playwright + viem)",
  "license": "MIT",
  "author": {
    "name": "cardene",
    "url": "https://github.com/cardene777"
  },
  "keywords": [
    "dapp",
    "ethereum",
    "e2e",
    "playwright",
    "anvil",
    "viem",
    "testing",
    "fixture"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cardene777/kiwa.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/cardene777/kiwa#readme",
  "bugs": {
    "url": "https://github.com/cardene777/kiwa/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.ja.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "test": "node -e \"require('node:fs').rmSync('.vitest-dist',{recursive:true,force:true})\" && tsc -p tsconfig.vitest.json && vitest run .vitest-dist/tests --environment node --testTimeout 15000 --no-file-parallelism",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@playwright/test": "^1.49.0",
    "viem": "^2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "viem": "^2.21.0"
  }
}
